# ============ NA 后端配置 ============
# NA 实例的内部地址
NA_BACKEND_URL=http://host.docker.internal:8054

# NA 后端管理员账号（用于代理请求时获取 token）
NA_ADMIN_USERNAME=admin
NA_ADMIN_PASSWORD=你的NA管理员密码

# ============ 面板用户配置 ============
# 面板用户账号（格式: user1:pass1,user2:pass2 支持多用户）
PANEL_USERS=user1:password123

# ============ 面板安全配置 ============
# JWT 密钥（请修改为随机字符串）
PANEL_JWT_SECRET=请替换为一个随机字符串
PANEL_JWT_EXPIRE_HOURS=24

# ============ 模型组权限 ============
# 用户可管理的模型组名称（逗号分隔）
# 留空 = 不允许管理任何模型组
# 示例: user_openai,user_claude
ALLOWED_MODEL_GROUPS=

# ============ 功能开关 ============
# 是否阻止频道覆盖配置（true/false）
CHANNEL_OVERRIDE_BLOCKED=true

# ============ 服务端口 ============
PANEL_PORT=9054
